<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Allow ImageCropper to access files in the app’s cache directory -->
    <cache-path
        name="cache"
        path="."/>

    <!-- Allow access to the external cache directory -->
    <external-cache-path
        name="external_cache"
        path="."/>

    <!-- Allow access to external files (e.g. picked images) -->
    <external-files-path
        name="external_files"
        path="."/>
</paths>
